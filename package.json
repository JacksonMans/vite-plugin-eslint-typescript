{
  "name": "@mawns/vite-plugin-eslint",
  "version": "1.1.3",
  "description": "vite plugin for eslint",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "tsup --watch",
    "test": "jest",
    "build": "npm run build:sass & npm run build:script & tsup",
    "build:sass": "tsup src/style/index.scss & copy dist\\index.css src\\style\\index.css",
    "build:script": "tsup src/script/index.ts & copy dist\\index.mjs src\\script\\index.mjs",
    "lint": "eslint ./src --ext .js,.ts",
    "pub": "npm run build & npm publish"
  },
  "keywords": [
    "vite",
    "plugin",
    "eslint",
    "overlay"
  ],
  "author": "mawns",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "esbuild-plugin-inline-import": "^1.1.0",
    "esbuild-sass-plugin": "^3.3.1",
    "jest": "^29.7.0",
    "release-please": "^16.18.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5"
  },
  "peerDependencies": {
    "eslint": "^9.14.0",
    "vite": "^6.2.0"
  }
}

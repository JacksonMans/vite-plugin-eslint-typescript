{
  "name": "@mawns/vite-plugin-eslint",
  "version": "1.4.0",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    },
    "./typescript-worker": {
      "import": "./dist/typescript-worker.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "knip": "knip --config knip.json",
    "depcheck": "depcheck .",
    "prepublishOnly": "npm run build",
    "pub": "npm publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "@typescript-eslint/parser": "^8.28.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "knip": "^5.46.2",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0",
    "vite": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JacksonMans/vite-plugin-eslint.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Vite plugin to display eslint and typescript errors in your app",
  "keywords": [
    "eslint",
    "typescript",
    "vite",
    "plugin"
  ],
  "author": "mawns",
  "license": "MIT"
}

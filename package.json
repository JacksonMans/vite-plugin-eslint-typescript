{
  "name": "@mawns/vite-plugin-eslint",
  "version": "1.3.0",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js",
      "require": "./dist/script.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "knip": "knip --config knip.json",
    "depcheck": "depcheck ."
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.3.0",
    "@typescript-eslint/parser": "^8.28.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "knip": "^5.46.2",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^7.1.2",
    "vite-plugin-dts": "^4.5.3"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "vite": "^7.1.2"
  },
  "description": "Vite plugin to display eslint and typescript errors in your app",
  "keywords": [
    "eslint",
    "typescript",
    "vite",
    "plugin"
  ],
  "author": "mawns",
  "license": "MIT"
}

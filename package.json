{
  "name": "vite-plugin-eslint-typescript",
  "version": "1.0.0",
  "main": "./dist/plugin.js",
  "module": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./script": {
      "types": "./dist/script.d.ts",
      "import": "./dist/script.js"
    },
    "./typescript-worker": {
      "import": "./dist/typescript-worker.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "knip": "knip --config knip.json",
    "depcheck": "depcheck .",
    "prepublishOnly": "npm run build",
    "pub": "npm publish"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.3",
    "depcheck": "^1.4.7",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "knip": "^6.0.4",
    "prettier": "^3.5.3",
    "sass": "^1.85.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "typescript": ">=5.0.0",
    "vite": ">=7.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JacksonMans/vite-plugin-eslint-typescript.git"
  },
  "description": "Vite plugin that runs ESLint and TypeScript type-checking during development with an in-browser error overlay",
  "keywords": [
    "vite",
    "vite-plugin",
    "eslint",
    "typescript",
    "linter",
    "lint",
    "type-check",
    "type-checking",
    "overlay",
    "hmr",
    "dx",
    "developer-experience",
    "diagnostics",
    "errors"
  ],
  "author": "mawns",
  "license": "MIT"
}

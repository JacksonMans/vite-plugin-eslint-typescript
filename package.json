{
  "name": "@mawns/vite-plugin-eslint",
  "version": "1.0.10",
  "description": "vite plugin for eslint",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "tsup --watch",
    "test": "jest",
    "build": "tsup",
    "lint": "eslint ./src --ext .js,.ts",
    "pub": "npm run build & npm publish"
  },
  "keywords": [
    "vite",
    "plugin",
    "eslint",
    "overlay"
  ],
  "author": "mawns",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "esbuild-sass-plugin": "^3.3.1",
    "jest": "^29.7.0",
    "lit-element": "^4.1.1",
    "release-please": "^16.14.3",
    "ts-jest": "^29.2.5",
    "tsup": "^8.1.0",
    "typed-scss-modules": "^8.0.1"
  },
  "peerDependencies": {
    "eslint": "^9.14.0",
    "vite": "^5.4.11"
  }
}
